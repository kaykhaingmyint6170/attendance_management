{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && node generate-html.cjs && printf '/assets/*  /assets/:splat  200\n/*         /index.html     200\n' > public/build/_redirects",
    "dev": "vite",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.41.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "axios": "^1.17.0",
    "concurrently": "^9.0.1",
    "laravel-vite-plugin": "^3.1",
    "node-fetch": "^2.7.0",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "wrangler": "^4.101.0"
  }
}
